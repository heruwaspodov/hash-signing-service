APP_ENV="local"
APP_LANG="en"
APP_PORT="7777"
APP_TIMEZONE="Asia/Jakarta"
APP_SECRET_KEY=thisisaverysecretkeywith32chars!
ENABLE_CORS=true
ENABLE_LOGGER=true

# ── Signer Backend ────────────────────────────────────────────────────────────
# "file"   → use PEM private key from CERT_KEY_FILE (default, for local dev)
# "pkcs11" → use a PKCS#11 module (SoftHSM2 or AWS CloudHSM)
# "kms"    → provider-based KMS path; set KMS_PROVIDER=aws or alicloud
SIGNER_BACKEND=file

# ── Certificate Files ────────────────────────────────────────────────────────
# file and alicloud local modes use CERT_KEY_FILE for signing.
# pkcs11, kms/aws, and alicloud remote do not load CERT_KEY_FILE for signing,
# but the certificate chain is still loaded for the established CMS flow.
CERT_FILE=certs/signing.crt
CERT_KEY_FILE=certs/signing.key
CERT_SUB_CA_FILE=certs/sub-ca.crt
CERT_ROOT_CA_FILE=certs/root-ca.crt

# ── PKCS#11 / HSM Signer (SIGNER_BACKEND=pkcs11) ────────────────────────────
# HSM_MODULE_PATH=/usr/lib/softhsm/libsofthsm2.so      # SoftHSM2 on Linux
# HSM_MODULE_PATH=/opt/homebrew/lib/softhsm/libsofthsm2.dylib  # SoftHSM2 on macOS (Homebrew)
# HSM_MODULE_PATH=/opt/cloudhsm/lib/libcloudhsm_pkcs11.so      # AWS CloudHSM
HSM_MODULE_PATH=/usr/lib/softhsm/libsofthsm2.so
HSM_TOKEN_LABEL=dev-signing-token
HSM_PIN=1234
HSM_KEY_LABEL=pdf-sign-key
# HSM_KEY_ID=01  # hex CKA_ID — optional, set to avoid ambiguity if multiple keys share the same label

# ── Generic KMS Signer (SIGNER_BACKEND=kms) ──────────────────────────────────
# SIGNER_BACKEND=kms
# KMS_PROVIDER=aws
# KMS_TIMEOUT_SECONDS=10

# ── AWS Provider (SIGNER_BACKEND=kms, KMS_PROVIDER=aws) ──────────────────────
# AWS_KMS_REGION=ap-southeast-1
# AWS_KMS_KEY_ID=alias/msign-local-signing
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# AWS_ENDPOINT_URL_KMS=http://localhost:4566  # LocalStack/local integration only

# ── Alibaba Cloud KMS Provider (SIGNER_BACKEND=kms, KMS_PROVIDER=alicloud) ───
# local: signs with CERT_KEY_FILE; no network call; intended only for APP_ENV=local/test.
# remote: fail-fast until the exact Alibaba KMS asymmetric sign API contract is verified.
# SIGNER_BACKEND=kms
# KMS_PROVIDER=alicloud
# KMS_TIMEOUT_SECONDS=10
# ALICLOUD_KMS_MODE=local
# ALICLOUD_KMS_LOCAL_SCENARIO=success

# Local fault-injection scenarios:
# success, key_not_found, key_disabled, access_denied, throttled, timeout,
# internal_error, invalid_signature

# Required only when ALICLOUD_KMS_MODE=remote:
# ALICLOUD_KMS_KEY_ID=
# ALICLOUD_KMS_ENDPOINT=
# ALICLOUD_REGION_ID=
# ALICLOUD_ACCESS_KEY_ID=
# ALICLOUD_ACCESS_KEY_SECRET=
